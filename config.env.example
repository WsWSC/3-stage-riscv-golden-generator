# Windows repo path as seen from WSL.
TARGET_REPO=/mnt/c/Users/<windows_user>/Documents/3-stage_RISC-V

# WSL-side ACT4 source location.
RISCV_HOME=$HOME/risc-v
ACT4_REPO=$RISCV_HOME/riscv-arch-test

# Local generator cache. Keep this inside the generator repo.
ACT4_WORK=$GENERATOR_ROOT/.work/act4_work

# Optional: set this only if sail_riscv_sim is not already in PATH.
# SAIL_RISCV_SIM=$HOME/.local/bin/sail_riscv_sim

# ACT4 extensions to build.
EXTENSIONS="I M"
